  "keyFeatures": [
    "JWT-based authentication and authorization with Spring Security",
    "Complete CRUD operations for books and users with pagination support",
    "OpenLibrary API integration for external book search by ISBN",
    "Layered architecture with clear separation of concerns",
    "Comprehensive exception handling with global error responses",
    "Interactive Swagger/OpenAPI documentation",
    "PostgreSQL database integration with JPA/Hibernate",
    "MapStruct for efficient DTO mapping",
    "Extensive unit and integration test coverage"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register - User registration",
    "POST /api/v1/auth/login - User authentication",
    "GET /api/v1/books/findAll - List all books with pagination and filters",
    "GET /api/v1/books/findById/{id} - Get book by ID",
    "GET /api/v1/books/isbn/{isbn} - Search book by ISBN",
    "POST /api/v1/books/create - Create new book",
    "PUT /api/v1/books/update/{id} - Update book",
    "DELETE /api/v1/books/delete/{id} - Delete book",
    "GET /api/v1/users/findAll - List all users with pagination",
    "GET /api/v1/users/findById/{id} - Get user by ID",
    "GET /api/v1/users/logged - Get currently logged-in user",
    "PUT /api/v1/users/update/{id} - Update user",
    "DELETE /api/v1/users/delete/{id} - Delete user",
    "POST /api/v1/users/{userId}/books/{bookId} - Add book to user collection",
    "DELETE /api/v1/users/{userId}/books/{bookId} - Remove book from user collection"
  ]
}
